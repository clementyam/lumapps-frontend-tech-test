{
	"compilerOptions": {
		"allowJs": true,
		"esModuleInterop": true,
		"jsx": "react",
		"lib": ["es2020", "dom"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"target": "ES2018",
		"downlevelIteration": true
	},
	"include": ["src", "vite.config.mts", "vitest.config.ts"]
}
